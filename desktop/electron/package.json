{
  "name": "thermoanalyzer-desktop",
  "version": "0.1.0",
  "private": true,
  "author": "ThermoAnalyzer Team",
  "description": "ThermoAnalyzer desktop app with bundled Python backend runtime",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test:startup-paths": "node ./scripts/test-backend-locator.js",
    "test:startup-diagnostics": "node ./scripts/test-startup-diagnostics.js",
    "test:desktop-smoke": "npm run test:startup-paths && npm run test:startup-diagnostics",
    "build:backend": "python ../backend_bundle/build_backend.py --clean",
    "build:win:dir": "npm run build:backend && electron-builder --win dir --x64",
    "build:win:portable": "npm run build:backend && electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.thermoanalyzer.desktop",
    "productName": "ThermoAnalyzer Desktop",
    "directories": {
      "output": "../../release/electron"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "renderer.js",
      "backend_locator.js",
      "startup_diagnostics.js",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend_bundle/dist/thermoanalyzer_backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "assets/thermoanalyzer.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ThermoAnalyzer-Desktop-${version}-${arch}.${ext}"
    }
  }
}
